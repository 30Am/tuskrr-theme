<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#1F3A2E">

  <title>
    {%- if page_title == blank -%}
      {{ shop.name }} — Modern utility, quietly built.
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  <meta property="og:type" content="website">
  {% if page_image %}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name }}">

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-backdrop"></div>
    <div class="mobile-menu-drawer">
      <button class="mobile-menu-close" aria-label="Close menu">✕</button>
      <nav class="mobile-nav-links">
        {% for link in linklists.main-menu.links %}
          <a class="mobile-nav-link" href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </nav>
    </div>
  </div>

  <!-- Announcement Bar -->
  {% section 'announcement-bar' %}

  <!-- Header -->
  {% section 'header' %}

  <!-- Main Content -->
  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% section 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
