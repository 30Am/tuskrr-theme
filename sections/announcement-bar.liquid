<div class="announcement-bar">
  <div class="container">
    <p>{{ section.settings.text }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping over Rs 2,500 · Free returns within 14 days · Made in India"
    }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
