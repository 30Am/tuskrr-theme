<section class="journal-section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="serif-headline">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="journal-grid">
      {% assign blog = blogs[section.settings.blog] %}
      {% if blog != blank and blog.articles.size > 0 %}
        {% for article in blog.articles limit: 3 %}
          <article class="journal-card">
            <a href="{{ article.url }}">
              <div class="journal-card-image">
                {% if article.image %}
                  {{
                    article.image
                    | image_url: width: 700
                    | image_tag: loading: 'lazy', alt: article.title
                  }}
                {% else %}
                  <div style="width:100%;height:100%;background:#D4D0C6;"></div>
                {% endif %}
              </div>
            </a>
            <p class="journal-category">
              {% if article.tags.size > 0 %}{{ article.tags.first | upcase }}{% endif %}
            </p>
            <h3 class="journal-title">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h3>
            <div class="journal-footer">
              <span class="journal-date">{{ article.published_at | date: '%d %b %Y' }}</span>
              <a class="journal-read" href="{{ article.url }}">Read &rarr;</a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          <article class="journal-card" {{ block.shopify_attributes }}>
            <div class="journal-card-image">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy' }}
              {% else %}
                <div style="width:100%;height:100%;background:#D4D0C6;"></div>
              {% endif %}
            </div>
            <p class="journal-category">{{ block.settings.category }}</p>
            <h3 class="journal-title">{{ block.settings.title }}</h3>
            <div class="journal-footer">
              <span class="journal-date">{{ block.settings.date }}</span>
              <a class="journal-read" href="{{ block.settings.url }}">Read &rarr;</a>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Journal",
  "settings": [
    { "type": "text",   "id": "eyebrow",  "label": "Eyebrow",  "default": "THE JOURNAL" },
    { "type": "text",   "id": "heading",  "label": "Heading",  "default": "Field notes from the foothills." },
    { "type": "blog",   "id": "blog",     "label": "Blog" }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article (fallback)",
      "settings": [
        { "type": "image_picker", "id": "image",    "label": "Image" },
        { "type": "text",         "id": "category", "label": "Category",  "default": "FIELD NOTES" },
        { "type": "text",         "id": "title",    "label": "Title",     "default": "A morning in the foothills." },
        { "type": "text",         "id": "date",     "label": "Date",      "default": "04 Apr 2026" },
        { "type": "url",          "id": "url",      "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Journal",
      "blocks": [
        { "type": "article", "settings": { "category": "FIELD NOTES",  "title": "A morning in the foothills, with notebook and a Sela Sleeve.", "date": "04 Apr 2026" } },
        { "type": "article", "settings": { "category": "CONSERVATION", "title": "Right of Passage: how Wildlife Trust of India keeps elephants moving.", "date": "21 Mar 2026" } },
        { "type": "article", "settings": { "category": "MATERIAL",     "title": "Why we chose recycled nylon for the Cabin Fifteen.", "date": "02 Mar 2026" } }
      ]
    }
  ]
}
{% endschema %}
