<section class="products-section">
  <div class="container">
    <div class="section-head">
      <div class="section-head-left">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="serif-headline">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="products-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection != blank and collection.products.size > 0 %}
        {% for product in collection.products limit: section.settings.product_count %}
          <div class="product-card">
            <a href="{{ product.url }}">
              <div class="product-card-image">
                {% if product.featured_image %}
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: product.title
                  }}
                {% else %}
                  <div style="width:100%;height:100%;background:#DDD8CC;"></div>
                {% endif %}
                {% if product.tags contains 'new' %}
                  <span class="product-badge">New</span>
                {% elsif product.tags contains 'best-seller' %}
                  <span class="product-badge">Best seller</span>
                {% endif %}
              </div>
            </a>
            <a href="{{ product.url }}">
              <p class="product-name">{{ product.title }}</p>
              <p class="product-variant">{{ product.selected_or_first_available_variant.title }}</p>
              <p class="product-price">{{ product.price | money }}</p>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <!-- Fallback preview blocks for theme editor -->
        {% for block in section.blocks %}
          <div class="product-card" {{ block.shopify_attributes }}>
            <div class="product-card-image">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {% else %}
                <div style="width:100%;height:100%;background:#DDD8CC;"></div>
              {% endif %}
              {% if block.settings.badge != blank %}
                <span class="product-badge">{{ block.settings.badge }}</span>
              {% endif %}
            </div>
            <p class="product-name">{{ block.settings.name }}</p>
            <p class="product-variant">{{ block.settings.variant }}</p>
            <p class="product-price">{{ block.settings.price }}</p>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="products-footer">
      <a class="view-all-link" href="{{ section.settings.view_all_url }}">
        View all products &rarr;
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text",       "id": "eyebrow",       "label": "Eyebrow",         "default": "THE RANGE" },
    { "type": "text",       "id": "heading",        "label": "Heading",         "default": "Built to last, made for many uses." },
    { "type": "collection", "id": "collection",     "label": "Collection" },
    { "type": "range",      "id": "product_count",  "label": "No. of products", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "url",        "id": "view_all_url",   "label": "View all URL",    "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product (fallback)",
      "settings": [
        { "type": "image_picker", "id": "image",   "label": "Image" },
        { "type": "text",         "id": "badge",   "label": "Badge",    "default": "" },
        { "type": "text",         "id": "name",    "label": "Name",     "default": "Product Name" },
        { "type": "text",         "id": "variant", "label": "Variant",  "default": "One size" },
        { "type": "text",         "id": "price",   "label": "Price",    "default": "Rs 0" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured products",
      "blocks": [
        { "type": "product", "settings": { "badge": "New",         "name": "Cabin Fifteen Sleeve", "variant": "Tuskwood / 15\"", "price": "Rs 2,490" } },
        { "type": "product", "settings": { "badge": "",            "name": "Brahmaputra Trolley",  "variant": "Cabin / 55cm",    "price": "Rs 12,990" } },
        { "type": "product", "settings": { "badge": "Best seller", "name": "Tusk Tumbler",         "variant": "Insulated 750ml", "price": "Rs 1,290" } },
        { "type": "product", "settings": { "badge": "",            "name": "Sela Tech Sleeve",     "variant": "Fog / 13\"",      "price": "Rs 1,890" } }
      ]
    }
  ]
}
{% endschema %}
