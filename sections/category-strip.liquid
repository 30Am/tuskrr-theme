<div class="category-strip">
  <div class="container">
    <div class="category-strip-inner">
      {% for block in section.blocks %}
        <a class="cat-item {% if block.settings.label contains 'soon' %}cat-item--muted{% endif %}"
           href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          {{ block.settings.label }}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category strip",
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url",  "id": "url",   "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Category strip",
    "blocks": [
      { "type": "category", "settings": { "label": "Travel" } },
      { "type": "category", "settings": { "label": "Tech" } },
      { "type": "category", "settings": { "label": "Tabletop" } },
      { "type": "category", "settings": { "label": "Apparel (soon)" } },
      { "type": "category", "settings": { "label": "Gift" } }
    ]
  }]
}
{% endschema %}
