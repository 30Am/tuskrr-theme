<section class="brand-story-section">
  <div class="brand-story-left">
    <div class="brand-story-copy">
      <p class="eyebrow" style="color:var(--sage-mist);">{{ section.settings.eyebrow }}</p>
      <h2 class="serif-headline brand-story-headline">{{ section.settings.headline }}</h2>
      <p class="brand-story-body">{{ section.settings.body }}</p>
      <a class="brand-story-link" href="{{ section.settings.link_url }}">
        {{ section.settings.link_label }} &rarr;
      </a>
    </div>
  </div>
  <div class="brand-story-right">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.eyebrow }}
    {% else %}
      <div style="width:100%;height:100%;background:#2C3D30;display:flex;align-items:center;justify-content:center;">
        <span style="color:#4A6850;font-size:12px;letter-spacing:2px;">BRAND IMAGE</span>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "text",         "id": "eyebrow",    "label": "Eyebrow",     "default": "THE BRAND" },
    { "type": "textarea",     "id": "headline",   "label": "Headline",    "default": "Designed in the foothills." },
    { "type": "textarea",     "id": "body",        "label": "Body",        "default": "Built to last, made for many uses, designed for years." },
    { "type": "text",         "id": "link_label", "label": "Link label",  "default": "Discover the story" },
    { "type": "url",          "id": "link_url",   "label": "Link URL" },
    { "type": "image_picker", "id": "image",      "label": "Image" }
  ],
  "presets": [{ "name": "Brand story" }]
}
{% endschema %}
