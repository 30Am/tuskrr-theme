<section class="hero-section">
  <div class="hero-content">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="serif-headline hero-headline">{{ section.settings.headline }}</h1>
    <p class="hero-sub">{{ section.settings.subheadline }}</p>
    <div class="hero-actions">
      <a class="btn-primary" href="/collections/all">{{ section.settings.cta_label }}</a>
      <a class="hero-link" href="/pages/brand">{{ section.settings.secondary_label }} &rarr;</a>
    </div>
  </div>
  <div class="hero-image">
    <div style="width:100%;height:100%;background:#243328;display:flex;align-items:center;justify-content:center;">
      <span style="color:#4A6850;font-size:13px;letter-spacing:2px;">ADD HERO IMAGE</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow",       "default": "NEW SEASON · 2026" },
    { "type": "textarea", "id": "headline",        "label": "Headline",      "default": "Modern utility, quietly built." },
    { "type": "text",     "id": "subheadline",     "label": "Sub-headline",  "default": "Range, made for movement." },
    { "type": "text",     "id": "cta_label",       "label": "CTA label",     "default": "Shop the range" },
    { "type": "text",     "id": "secondary_label", "label": "Secondary CTA", "default": "Discover the story" },
    { "type": "image_picker", "id": "image",       "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
