<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <!-- Brand column -->
      <div class="footer-brand-col">
        <a class="site-logo" href="{{ routes.root_url }}">{{ shop.name | upcase }}</a>
        <p class="footer-brand-tagline">{{ section.settings.tagline }}</p>
      </div>

      <!-- Link columns -->
      {% for block in section.blocks %}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <p class="footer-col-heading">{{ block.settings.heading }}</p>
          <ul>
            {% for i in (1..5) %}
              {% assign label_key = 'link_' | append: i | append: '_label' %}
              {% assign url_key   = 'link_' | append: i | append: '_url' %}
              {% if block.settings[label_key] != blank %}
                <li><a href="{{ block.settings[url_key] | default: '#' }}">{{ block.settings[label_key] }}</a></li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>

    <hr class="divider">

    <div class="footer-bottom">
      <p class="footer-copy">{{ section.settings.copyright }}</p>
      <div class="footer-bottom-links">
        <a href="{{ routes.root_url }}pages/privacy-policy">Privacy</a>
        <a href="{{ routes.root_url }}pages/terms-of-service">Terms</a>
        {% if section.settings.instagram != blank %}
          <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener">Instagram</a>
        {% endif %}
        {% if section.settings.youtube != blank %}
          <a href="{{ section.settings.youtube }}" target="_blank" rel="noopener">YouTube</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline",   "label": "Brand tagline",  "default": "Modern utility crafted from the wisdom of the wild." },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 TUSKRR Lifestyle Pvt Ltd · Made in India" },
    { "type": "url",  "id": "instagram", "label": "Instagram URL" },
    { "type": "url",  "id": "youtube",   "label": "YouTube URL" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading",      "label": "Heading",  "default": "Shop" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" }, { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" }, { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" }, { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" }, { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" }, { "type": "url", "id": "link_5_url", "label": "Link 5 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Shop",  "link_1_label": "Travel", "link_2_label": "Tech", "link_3_label": "Tabletop", "link_4_label": "Gift" } },
        { "type": "link_column", "settings": { "heading": "Brand", "link_1_label": "About",  "link_2_label": "Conservation", "link_3_label": "Journal", "link_4_label": "Press" } },
        { "type": "link_column", "settings": { "heading": "Care",  "link_1_label": "Repair & refurbish", "link_2_label": "Returns", "link_3_label": "Warranty", "link_4_label": "Care guides" } },
        { "type": "link_column", "settings": { "heading": "Help",  "link_1_label": "Contact", "link_2_label": "Track order", "link_3_label": "Size guide", "link_4_label": "FAQ" } }
      ]
    }
  ]
}
{% endschema %}
