<div class="product-page">
  <div class="container">
    <div class="product-page-grid">

      <!-- Gallery -->
      <div>
        <div class="product-gallery-main">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: product.title }}
          {% else %}
            <div style="width:100%;height:100%;background:#DDD8CC;"></div>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-gallery-thumbs">
            {% for image in product.images limit: 4 %}
              <div class="product-gallery-thumb {% if forloop.first %}active{% endif %}"
                   data-src="{{ image | image_url: width: 1200 }}">
                {{ image | image_url: width: 200 | image_tag: loading: 'lazy', alt: image.alt }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Info -->
      <div class="product-page-info">
        <p class="eyebrow">
          {% if product.collections.size > 0 %}{{ product.collections.first.title }}{% endif %}
        </p>
        <h1 class="product-page-title">{{ product.title }}</h1>
        <p class="product-page-price">
          {% if product.compare_at_price > product.price %}
            <s style="color:var(--hide);font-size:16px;font-weight:400;">
              {{ product.compare_at_price | money }}
            </s>&nbsp;
          {% endif %}
          {{ product.price | money }}
        </p>
        <p class="product-page-desc">{{ product.description }}</p>

        {% form 'product', product %}
          <!-- Variants -->
          {% unless product.has_only_default_variant %}
            {% for option in product.options_with_values %}
              <p class="variant-label">{{ option.name }}</p>
              <div class="variant-options">
                {% for value in option.values %}
                  <label class="variant-option {% if option.selected_value == value %}selected{% endif %}">
                    {{ value }}
                  </label>
                {% endfor %}
              </div>
            {% endfor %}
            <select name="id" style="display:none;">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}"
                  {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {% endunless %}

          <!-- Add to cart -->
          {% if product.available %}
            <button class="atc-btn" type="submit" name="add">Add to bag</button>
          {% else %}
            <button class="atc-btn" disabled style="opacity:0.5;cursor:not-allowed;">Sold out</button>
          {% endif %}
        {% endform %}

        <!-- Accordion -->
        <div class="product-details-accordion">
          {% for block in section.blocks %}
            {% if block.type == 'accordion' %}
              <div class="accordion-item" {{ block.shopify_attributes }}>
                <button class="accordion-trigger">
                  {{ block.settings.heading }}
                  <span class="acc-icon">+</span>
                </button>
                <div class="accordion-content">
                  {{ block.settings.content }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product page",
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text",     "id": "heading", "label": "Heading", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Product details here.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Product page" }]
}
{% endschema %}
